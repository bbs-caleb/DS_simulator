<span class=3D"hljs-keyword">def</span> <span class=3D"hljs-title function_=
">cpc_sample</span>(<span class=3D"hljs-params">
    n_samples: <span class=3D"hljs-built_in">int</span>, conversion_rate: <=
span class=3D"hljs-built_in">float</span>, reward_avg: <span class=3D"hljs-=
built_in">float</span>, reward_std: <span class=3D"hljs-built_in">float</sp=
an>
</span>) -&gt; np.ndarray:
    <span class=3D"hljs-string">"""Sample data."""</span>
    cvr =3D np.random.binomial(<span class=3D"hljs-number">1</span>, conver=
sion_rate, n_samples)
