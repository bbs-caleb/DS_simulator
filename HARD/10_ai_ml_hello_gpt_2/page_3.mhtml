    input_ids =3D encoder.encode(prompt)
    <span class=3D"hljs-keyword">assert</span> <span class=3D"hljs-built_in=
">len</span>(input_ids) + n_tokens &lt; hparams[<span class=3D"hljs-string"=
>"n_ctx"</span>]

    <span class=3D"hljs-comment"># Generate tokens, this time we don't need=
 to pass the vocab</span>
    <span class=3D"hljs-comment"># because the 'generate' function will acc=
ept token IDs</span>
    <span class=3D"hljs-comment"># as input and return token IDs as output<=
/span>
    output_ids =3D generate(
        llm=3Dgpt2,
        input_ids=3Dinput_ids,
        n_tokens=3Dn_tokens,
        top_k=3D<span class=3D"hljs-number">50</span>,
        top_p=3D<span class=3D"hljs-number">0.8</span>,
        temperature=3D<span class=3D"hljs-number">0.75</span>,
        random_state=3D<span class=3D"hljs-number">0</span>,
        weights=3Dweights,
    )

    <span class=3D"hljs-comment"># Decode output token IDs using the encode=
r, it will convert</span>
    <span class=3D"hljs-comment"># the token IDs to a string for us based o=
n its vocabulary</span>
    output =3D encoder.decode(output_ids)

    <span class=3D"hljs-keyword">return</span> output


<span class=3D"hljs-keyword">if</span> __name__ =3D=3D <span class=3D"hljs-=
string">"__main__"</span>:
    <span class=3D"hljs-keyword">import</span> fire

    fire.Fire(main)
