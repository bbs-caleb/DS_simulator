<span class=3D"hljs-keyword">def</span> <span class=3D"hljs-title function_=
">generate</span>(<span class=3D"hljs-params">
    llm: <span class=3D"hljs-type">Callable</span>[[<span class=3D"hljs-typ=
e">List</span>[<span class=3D"hljs-built_in">int</span>]], <span class=3D"h=
ljs-type">List</span>[<span class=3D"hljs-built_in">float</span>]],
    input_ids: <span class=3D"hljs-type">List</span>[<span class=3D"hljs-bu=
ilt_in">int</span>],
    n_tokens: <span class=3D"hljs-built_in">int</span>,
    top_k: <span class=3D"hljs-built_in">int</span> =3D <span class=3D"hljs=
-number">1</span>,
    top_p: <span class=3D"hljs-built_in">float</span> =3D <span class=3D"hl=
js-number">0.75</span>,
    temperature: <span class=3D"hljs-built_in">float</span> =3D <span class=
=3D"hljs-number">1.0</span>,
    weights: <span class=3D"hljs-built_in">dict</span> =3D <span class=3D"h=
ljs-literal">None</span>,
    random_state: <span class=3D"hljs-built_in">int</span> =3D <span class=
=3D"hljs-number">0</span>,
</span>) -&gt; <span class=3D"hljs-type">List</span>[<span class=3D"hljs-bu=
ilt_in">int</span>]:
    <span class=3D"hljs-string">"""Generate a sequence of tokens from a pro=
mpt using a language model."""</span>
    np.random.seed(random_state)
    output_ids =3D []

    <span class=3D"hljs-comment"># Auto-regressive decode loop</span>
    <span class=3D"hljs-keyword">for</span> _ <span class=3D"hljs-keyword">=
in</span> <span class=3D"hljs-built_in">range</span>(n_tokens):
        logits =3D llm(input_ids + output_ids, **weights)
        logits =3D np.array(logits)
        logits =3D logits / temperature
        probs =3D np.exp(logits) / np.exp(logits).<span class=3D"hljs-built=
_in">sum</span>()

        <span class=3D"hljs-comment"># Apply top-k filtering</span>
        indices =3D np.argsort(probs)[-top_k:]
        probs =3D probs[indices] / probs[indices].<span class=3D"hljs-built=
_in">sum</span>()

        order =3D np.argsort(probs)[::-<span class=3D"hljs-number">1</span>=
]
        indices =3D indices[order]
        probs =3D probs[order]

        <span class=3D"hljs-comment"># Apply top-p filtering</span>
        cum_probs =3D np.cumsum(probs)
        mask =3D cum_probs &lt;=3D np.<span class=3D"hljs-built_in">min</sp=
an>(cum_probs[cum_probs &gt;=3D top_p])
        probs =3D probs[mask] / probs[mask].<span class=3D"hljs-built_in">s=
um</span>()
        indices =3D indices[mask]

        next_id =3D <span class=3D"hljs-built_in">int</span>(np.random.choi=
ce(indices, p=3Dprobs))
        output_ids.append(next_id)

    <span class=3D"hljs-keyword">return</span> output_ids


