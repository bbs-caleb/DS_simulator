<span class=3D"hljs-keyword">def</span> <span class=3D"hljs-title function_=
">gelu</span>(<span class=3D"hljs-params">x</span>):
    <span class=3D"hljs-keyword">return</span> <span class=3D"hljs-number">=
0.5</span> * x * (<span class=3D"hljs-number">1</span> + np.tanh(np.sqrt(<s=
pan class=3D"hljs-number">2</span> / np.pi) * (x + <span class=3D"hljs-numb=
er">0.044715</span> * x**<span class=3D"hljs-number">3</span>)))


<span class=3D"hljs-keyword">def</span> <span class=3D"hljs-title function_=
">ffn</span>(<span class=3D"hljs-params">x, c_fc, c_proj</span>):  <span cl=
ass=3D"hljs-comment"># [n_seq, n_embd] -&gt; [n_seq, n_embd]</span>
    <span class=3D"hljs-comment"># project up</span>
    a =3D gelu(linear(x, **c_fc))  <span class=3D"hljs-comment"># [n_seq, n=
_embd] -&gt; [n_seq, 4*n_embd]</span>

    <span class=3D"hljs-comment"># project back down</span>
    x =3D linear(a, **c_proj)  <span class=3D"hljs-comment"># [n_seq, 4*n_e=
mbd] -&gt; [n_seq, n_embd]</span>

    <span class=3D"hljs-keyword">return</span> x


<span class=3D"hljs-keyword">def</span> <span class=3D"hljs-title function_=
">layer_norm</span>(<span class=3D"hljs-params">x, g, b, eps: <span class=
=3D"hljs-built_in">float</span> =3D <span class=3D"hljs-number">1e-5</span>=
</span>):
    mean =3D np.mean(x, axis=3D-<span class=3D"hljs-number">1</span>, keepd=
ims=3D<span class=3D"hljs-literal">True</span>)
    variance =3D np.var(x, axis=3D-<span class=3D"hljs-number">1</span>, ke=
epdims=3D<span class=3D"hljs-literal">True</span>)
    x =3D (x - mean) / np.sqrt(
        variance + eps
    )  <span class=3D"hljs-comment"># normalize x to have mean=3D0 and var=
=3D1 over last axis</span>
    <span class=3D"hljs-keyword">return</span> g * x + b  <span class=3D"hl=
js-comment"># scale and offset with gamma/beta params</span>


<span class=3D"hljs-keyword">def</span> <span class=3D"hljs-title function_=
">linear</span>(<span class=3D"hljs-params">x, w, b</span>):  <span class=
=3D"hljs-comment"># [m, in], [in, out], [out] -&gt; [m, out]</span>
    <span class=3D"hljs-keyword">return</span> x @ w + b


<span class=3D"hljs-keyword">def</span> <span class=3D"hljs-title function_=
">softmax</span>(<span class=3D"hljs-params">x</span>):
    exp_x =3D np.exp(x - np.<span class=3D"hljs-built_in">max</span>(x, axi=
s=3D-<span class=3D"hljs-number">1</span>, keepdims=3D<span class=3D"hljs-l=
iteral">True</span>))
    <span class=3D"hljs-keyword">return</span> exp_x / np.<span class=3D"hl=
js-built_in">sum</span>(exp_x, axis=3D-<span class=3D"hljs-number">1</span>=
, keepdims=3D<span class=3D"hljs-literal">True</span>)


<span class=3D"hljs-keyword">def</span> <span class=3D"hljs-title function_=
">attention</span>(<span class=3D"hljs-params">
    q, k, v, mask
</span>):  <span class=3D"hljs-comment"># [n_q, d_k], [n_k, d_k], [n_k, d_v=
], [n_q, n_k] -&gt; [n_q, d_v]</span>
    <span class=3D"hljs-keyword">return</span> softmax(q @ k.T / np.sqrt(q.=
shape[-<span class=3D"hljs-number">1</span>]) + mask) @ v


<span class=3D"hljs-keyword">def</span> <span class=3D"hljs-title function_=
">mha</span>(<span class=3D"hljs-params">x, c_attn, c_proj, n_head</span>):=
  <span class=3D"hljs-comment"># [n_seq, n_embd] -&gt; [n_seq, n_embd]</spa=
n>
    <span class=3D"hljs-comment"># qkv projection</span>
    x =3D linear(x, **c_attn)  <span class=3D"hljs-comment"># [n_seq, n_emb=
d] -&gt; [n_seq, 3*n_embd]</span>

    <span class=3D"hljs-comment"># split into qkv</span>
    qkv =3D np.split(x, <span class=3D"hljs-number">3</span>, axis=3D-<span=
 class=3D"hljs-number">1</span>)  <span class=3D"hljs-comment"># [n_seq, 3*=
n_embd] -&gt; [3, n_seq, n_embd]</span>

    <span class=3D"hljs-comment"># split into heads</span>
    qkv_heads =3D <span class=3D"hljs-built_in">list</span>(
        <span class=3D"hljs-built_in">map</span>(<span class=3D"hljs-keywor=
d">lambda</span> x: np.split(x, n_head, axis=3D-<span class=3D"hljs-number"=
>1</span>), qkv)
    )  <span class=3D"hljs-comment"># [3, n_seq, n_embd] -&gt; [3, n_head, =
n_seq, n_embd/n_head]</span>

    <span class=3D"hljs-comment"># causal mask to hide future inputs from b=
eing attended to</span>
    causal_mask =3D (<span class=3D"hljs-number">1</span> - np.tri(x.shape[=
<span class=3D"hljs-number">0</span>])) * -<span class=3D"hljs-number">1e10=
</span>  <span class=3D"hljs-comment"># [n_seq, n_seq]</span>

    <span class=3D"hljs-comment"># perform attention over each head</span>
    out_heads =3D [
        attention(q, k, v, causal_mask) <span class=3D"hljs-keyword">for</s=
pan> q, k, v <span class=3D"hljs-keyword">in</span> <span class=3D"hljs-bui=
lt_in">zip</span>(*qkv_heads)
    ]  <span class=3D"hljs-comment"># [3, n_head, n_seq, n_embd/n_head] -&g=
t; [n_head, n_seq, n_embd/n_head]</span>

    <span class=3D"hljs-comment"># merge heads</span>
    x =3D np.hstack(
        out_heads
    )  <span class=3D"hljs-comment"># [n_head, n_seq, n_embd/n_head] -&gt; =
[n_seq, n_embd]</span>

    <span class=3D"hljs-comment"># out projection</span>
    x =3D linear(x, **c_proj)  <span class=3D"hljs-comment"># [n_seq, n_emb=
d] -&gt; [n_seq, n_embd]</span>

    <span class=3D"hljs-keyword">return</span> x


<span class=3D"hljs-keyword">def</span> <span class=3D"hljs-title function_=
">transformer_block</span>(<span class=3D"hljs-params">
    x, mlp, attn, ln_1, ln_2, n_head
</span>):  <span class=3D"hljs-comment"># [n_seq, n_embd] -&gt; [n_seq, n_e=
mbd]</span>
    <span class=3D"hljs-comment"># multi-head causal self attention</span>
