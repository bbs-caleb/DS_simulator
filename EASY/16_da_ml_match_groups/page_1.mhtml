on: cubic-bezier(0.54, 1.5, 0.38, 1.11); }

.tippy-arrow { color: rgb(51, 51, 51); height: 1.14rem; width: 1.14rem; }

.tippy-arrow::before { border-color: transparent; border-style: solid; cont=
ent: ""; position: absolute; }

