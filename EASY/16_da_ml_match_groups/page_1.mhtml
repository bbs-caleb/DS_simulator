olor: initial; border-width: 0.57rem 0px 0.57rem 0.57rem; right: -0.5rem; t=
ransform-origin: left center; }

.tippy-box[data-placement^=3D"right"] > .tippy-arrow { left: 0px; }

.tippy-box[data-placement^=3D"right"] > .tippy-arrow::before { border-right=
-color: initial; border-width: 0.57rem 0.57rem 0.57rem 0px; left: -0.5rem; =
