        resample_exper =3D np.random.choice(experiment, size=3Dn_exper, rep=
lace=3D<span class=3D"hljs-literal">True</span>)

        boot_control.append(np.quantile(resample_control, quantile))
        boot_exper.append(np.quantile(resample_exper, quantile))

    _, p_value =3D ttest_ind(
        boot_control,
        boot_exper,
    )

